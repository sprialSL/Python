# OpenAI Compatible API Configuration
# Copy this file to .env and fill in your values

# API Base URL (OpenAI compatible endpoint)
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   Azure:      https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   Local:      http://localhost:8000/v1
#   Other:      https://your-api-provider.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API Key (Bearer Token)
OPENAI_API_KEY=sk-your-api-key-here

# Model Name
# Examples: gpt-4, gpt-3.5-turbo, claude-3-opus, your-model-name
OPENAI_MODEL=gpt-3.5-turbo

# Optional Parameters
TEMPERATURE=0.7
MAX_TOKENS=1000
TOP_P=1.0

# Streaming Mode (true/false)
# true: Real-time output, better user experience
# false: Wait for complete response
USE_STREAM=true
